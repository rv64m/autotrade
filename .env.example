# Trading configuration
TOTAL_CASH=100000
MARKET_TYPE=spot          # spot or swap

# Risk management
# Soft targets — strategies that fail these cannot be marked as 'keep'
MAX_DRAWDOWN_LIMIT=-20    # target max drawdown %, e.g. -20 means aim to stay above -20%
MIN_PROFIT_FACTOR=1.5     # target profit factor minimum, e.g. 1.5 means reward/risk ratio >= 1.5

# Hard limit — train.py raises an error if MAX_LEVERAGE exceeds this value
MAX_LEVERAGE_LIMIT=5.0    # maximum allowed leverage; Agent must correct train.py if exceeded

# Data source
EXCHANGE_ID=binance
SYMBOL=BTC/USDT
START_DATE=2023-01-01
END_DATE=                 # leave blank for up to today

# Optional crypto data config
CRYPTO_CACHE_DIR=./data
CRYPTO_FETCH_MAX_RETRIES=

# Optional network config
CRYPTO_HTTP_PROXY=

# Optional exchange credentials
CRYPTO_API_KEY=
CRYPTO_API_SECRET=
CRYPTO_API_PASSWORD=
