# Trading configuration
TOTAL_CASH=100000
MARKET_TYPE=spot          # spot or swap

# Risk limits (strategies exceeding these are rejected)
MAX_DRAWDOWN_LIMIT=-30    # maximum acceptable drawdown %, e.g. -30 means reject if drawdown < -30%
MIN_PROFIT_FACTOR=1.0     # minimum acceptable profit factor (risk-reward), reject if < this value

# Data source
EXCHANGE_ID=binance
SYMBOL=BTC/USDT
START_DATE=2023-01-01
END_DATE=                 # leave blank for up to today

# Optional crypto data config
CRYPTO_CACHE_DIR=./data
CRYPTO_FETCH_MAX_RETRIES=

# Optional network config
CRYPTO_HTTP_PROXY=

# Optional exchange credentials
CRYPTO_API_KEY=
CRYPTO_API_SECRET=
CRYPTO_API_PASSWORD=
